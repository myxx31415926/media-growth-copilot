# mock | webhook | app
FEISHU_PROVIDER=mock

# Option A: Feishu custom bot webhook. Recommended for the demo flow.
FEISHU_WEBHOOK_URL=

# Option B: Feishu internal app API.
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_RECEIVE_ID_TYPE=chat_id
FEISHU_RECEIVE_ID=

# Public or local URL opened from the Feishu card button.
DASHBOARD_URL=http://localhost:8766/dashboard/index.html
